<!DOCTYPE html>
<html lang="en" style="scroll-behavior: smooth;">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zakaria Amrouche</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #ffffff;
    --surface: #f8f8f6;
    --surface2: #f0efe9;
    --border: rgba(0,0,0,0.08);
    --text: #111111;
    --muted: #666;
    --accent: #f97316;
    --accent2: #ea6c0a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.2rem 2rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
  }

  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 2rem; justify-content: center; }
  .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
    gap: 4rem;
  }

  .hero-text { flex: 1; }

  .hero-badge {
    display: inline-block;
    background: rgba(249,115,22,0.1);
    color: #c2580a;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(249,115,22,0.25);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero h1 span { color: var(--accent); }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .hero-photo {
    width: 260px;
    height: 320px;
    border-radius: 16px;
    object-fit: cover;
    object-position: center top;
    border: 3px solid var(--accent);
    flex-shrink: 0;
  }

  /* STATS BAR */
  .stats-bar {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .stat { text-align: center; }
  .stat-num { font-size: 2rem; font-weight: 800; color: var(--accent); }
  .stat-label { font-size: 0.85rem; color: var(--muted); margin-top: 0.2rem; }

  /* SECTIONS */
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .section-tag {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.8rem;
  }

  .section-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .section-sub {
    color: var(--muted);
    font-size: 1rem;
    max-width: 560px;
    margin-bottom: 3rem;
  }

  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249,115,22,0.3), transparent);
    max-width: 1100px;
    margin: 0 auto;
  }

  /* VENTURES */
  .ventures-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .venture-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.8rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .venture-card:hover { border-color: rgba(249,115,22,0.3); transform: translateY(-2px); }

  .venture-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .venture-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.7; margin-bottom: 1.2rem; }

  .venture-lesson {
    background: rgba(249,115,22,0.07);
    border-left: 2px solid var(--accent);
    padding: 0.6rem 0.8rem;
    font-size: 0.82rem;
    color: #c2580a;
    border-radius: 0 4px 4px 0;
  }

  .venture-lesson strong { color: var(--accent); }

  /* PROOF */
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem;
  }

  .proof-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
  }

  .proof-card:hover { border-color: rgba(249,115,22,0.4); transform: translateY(-2px); }

  .proof-card-body { padding: 0.9rem 1rem; }
  .proof-card-title { font-weight: 600; font-size: 0.9rem; color: var(--text); margin: 0; }
  .proof-card-sub { font-size: 0.8rem; color: var(--muted); margin: 0.2rem 0 0; }

  /* SCORE BADGES */
  .score-badge { padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
  .score-good { background: rgba(22,163,74,0.1); color: #15803d; border: 1px solid rgba(22,163,74,0.25); }
  .score-poor { background: rgba(220,38,38,0.1); color: #b91c1c; border: 1px solid rgba(220,38,38,0.25); }

  /* ARTICLE ROWS */
  .article-row {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: border-color 0.2s, transform 0.2s;
    margin-bottom: 0.8rem;
  }

  .article-row:hover { border-color: rgba(249,115,22,0.4); transform: translateY(-1px); }
  .article-row-title { font-weight: 600; font-size: 0.95rem; color: var(--text); margin: 0; }
  .article-row-sub { font-size: 0.82rem; color: var(--muted); margin: 0.3rem 0 0; }

  /* VSL */
  .vsl-wrap {
    display: flex;
    justify-content: center;
  }

  /* FLOAT BUTTONS */
  .float-btn {
    position: fixed;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    border-radius: 100px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    transition: transform 0.2s, box-shadow 0.2s;
    border: none;
    cursor: pointer;
  }

  .float-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(0,0,0,0.18); }
  .float-call { top: 5rem; right: 1.5rem; background: var(--accent); color: white; }
  .float-whatsapp { bottom: 1.5rem; left: 1.5rem; background: #25D366; color: white; }
  .float-email { bottom: 1.5rem; right: 1.5rem; background: var(--text); color: white; }

  /* MODAL */
  #siteModal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .modal-inner {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 1200px;
    height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.3);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .modal-header span { font-weight: 600; font-size: 0.95rem; color: #111; }
  .modal-header a { font-size: 0.82rem; color: var(--accent); text-decoration: none; font-weight: 600; }
  .modal-header button { background: #f3f4f6; border: none; border-radius: 8px; padding: 0.4rem 0.8rem; cursor: pointer; font-size: 0.9rem; color: #444; }
  .modal-inner iframe { flex: 1; border: none; width: 100%; }

  footer {
    border-top: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    /* Nav */
    nav { grid-template-columns: 1fr 1fr; padding: 1rem 1.2rem; }
    .nav-links { display: none; }

    /* Hero */
    .hero {
      flex-direction: column;
      text-align: center;
      padding: 6rem 1.5rem 3rem;
      gap: 2rem;
    }
    .hero-photo { width: 140px; height: 175px; margin: 0 auto; }
    .hero h1 { font-size: 2.2rem; }
    .hero-desc { font-size: 0.95rem; margin: 0 auto 2rem; }
    .hero-badge { font-size: 0.72rem; }

    /* Stats bar */
    .stats-bar { gap: 1.5rem; padding: 1.5rem 1rem; }
    .stat-num { font-size: 1.5rem; }
    .stat-label { font-size: 0.75rem; }

    /* Sections */
    section { padding: 3rem 1.2rem; }
    .section-title { font-size: 1.8rem; }

    /* Ventures */
    .ventures-grid { grid-template-columns: 1fr; }

    /* Ads horizontal scroll */
    .ads-scroll-wrap {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 1rem;
      scrollbar-width: none;
    }
    .ads-scroll-wrap::-webkit-scrollbar { display: none; }
    .ads-scroll-wrap .ad-item {
      flex-shrink: 0;
      width: 200px;
      scroll-snap-align: start;
    }

    /* Websites grid */
    .proof-grid { grid-template-columns: 1fr 1fr !important; }

    /* YouTube + Audit side by side — stack on mobile */
    .yt-audit-grid { grid-template-columns: 1fr !important; }

    /* Articles grid */
    .articles-grid { grid-template-columns: 1fr !important; }

    /* Float buttons */
    .float-whatsapp { bottom: 1rem; left: 1rem; font-size: 0.8rem; padding: 0.7rem 1rem; }
    .float-email { bottom: 1rem; right: 1rem; font-size: 0.8rem; padding: 0.7rem 1rem; }
  }

  /* ── SCROLL ANIMATIONS ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-left {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal-left.visible {
    opacity: 1;
    transform: translateX(0);
  }
  .reveal-right {
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal-right.visible {
    opacity: 1;
    transform: translateX(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  /* Stat counter animation */
  .stat-num { transition: color 0.3s; }

  /* Hover lift for all cards */
  .venture-card, .proof-card, .article-card {
    transition: border-color 0.2s, transform 0.25s, box-shadow 0.25s;
  }
  .venture-card:hover, .proof-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(249,115,22,0.08);
  }

  /* Smooth active nav link */
  .nav-links a.active { color: var(--accent); font-weight: 600; }

  /* Hero text stagger */
  .hero-badge { animation: fadeUp 0.5s ease forwards; }
  .hero h1 { animation: fadeUp 0.6s ease 0.1s both; }
  .hero-desc { animation: fadeUp 0.6s ease 0.2s both; }
  .hero-photo { animation: fadeUp 0.7s ease 0.15s both; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Stats count-up pulse */
  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }
  .stat-num.counted { animation: pulse 0.4s ease; }



  /* Progress bar */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: var(--accent);
    z-index: 200;
    transition: width 0.1s linear;
  }

  /* Section tag animate in */
  .section-tag {
    position: relative;
    display: inline-block;
  }


  /* Back to top */
  .back-top {
    position: fixed;
    bottom: 5rem;
    right: 1.5rem;
    width: 42px;
    height: 42px;
    background: var(--text);
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 998;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s, transform 0.3s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .back-top.visible { opacity: 1; transform: translateY(0); }
  .back-top:hover { background: var(--accent); }

</style>
</head>
