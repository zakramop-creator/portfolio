function initMobileAds() {
  if (window.innerWidth <= 768) {
    const desktop = document.querySelector('.ads-desktop');
    if (!desktop) return;
    const videos = desktop.querySelectorAll('video');
    const srcs = Array.from(videos).map(v => v.src);

    const scroll = document.createElement('div');
    scroll.className = 'ads-scroll-wrap';
    scroll.style.marginBottom = '4rem';

    srcs.forEach(src => {
      const item = document.createElement('div');
      item.className = 'ad-item';
      item.style.cssText = 'flex-shrink:0; width:200px; scroll-snap-align:start; background:var(--surface); border:1px solid var(--border); border-radius:12px; overflow:hidden;';
      const vid = document.createElement('video');
      vid.src = src;
      vid.controls = true;
      vid.setAttribute('playsinline', '');
      vid.style.cssText = 'width:100%; display:block; aspect-ratio:9/16; object-fit:cover; background:#000;';
      item.appendChild(vid);
      scroll.appendChild(item);
    });

    desktop.replaceWith(scroll);
  }
}
